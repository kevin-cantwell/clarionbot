# ClarionBot Configuration
# Copy this file to config.env and fill in your values.

# Your name (used in CLAUDE.md self-instructions)
CLARIONBOT_OWNER=YourName

# The domain you use with expose for tunneling (e.g. example.com)
CLARIONBOT_DOMAIN=example.com

# Your dev directory (where your projects live)
CLARIONBOT_DEV_DIR=~/dev

# Ollama settings (for local conversation summarization)
OLLAMA_URL=http://localhost:11434/api/generate
OLLAMA_MODEL=qwen2.5:3b
